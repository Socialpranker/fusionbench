__pycache__/
*.pyc
.venv/
.env
.pytest_cache/
*.egg-info/
# site/ is build output (build_catalog.py generates index.html + data.json in CI).
# Only app.js is a hand-written source — ignore the rest. Note: must ignore site/*
# (contents), not site/ (the dir), or the !app.js re-include can't take effect.
site/*
!site/app.js
!site/leaderboard.js
runs/
*.jsonl.local
.DS_Store

# Plaintext gold answer keys — only the .enc form is committed.
gold/*.jsonl
!gold/.gitkeep
